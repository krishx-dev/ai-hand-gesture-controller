# ─────────────────────────────────────────────────────────────
# AI Hand Gesture Controller — Environment Variables Example
#
# Copy this file to `.env` and fill in values as needed.
# NEVER commit your real `.env` file to version control.
# All Vite env vars exposed to the browser MUST be prefixed
# with VITE_ — anything else stays server-side only.
# ─────────────────────────────────────────────────────────────

# ── App Meta ──────────────────────────────────────────────────
# Human-readable title shown in the browser tab / UI
VITE_APP_TITLE="AI Hand Gesture Controller"

# Deployment base URL (useful for sub-path deployments)
# e.g. "/gesture-app" for github pages, "/" for root
VITE_BASE_URL="/"

# ── MediaPipe Model Configuration ─────────────────────────────
# Override the CDN URL for MediaPipe Hands WASM assets.
# Leave empty to use the default MediaPipe CDN.
# VITE_MEDIAPIPE_CDN_URL="https://cdn.jsdelivr.net/npm/@mediapipe/hands"

# ── Feature Flags ─────────────────────────────────────────────
# Enable verbose gesture debug logging in the console
VITE_DEBUG_GESTURES="false"

# Show raw MediaPipe landmark data in the UI (dev only)
VITE_SHOW_RAW_LANDMARKS="false"

# ── Analytics (optional) ───────────────────────────────────────
# Add your analytics measurement ID here if integrating tracking.
# VITE_GA_MEASUREMENT_ID="G-XXXXXXXXXX"
